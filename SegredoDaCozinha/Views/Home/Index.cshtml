@model List<Receita>
@{
    ViewData["Title"] = "Home";
}
<!-- Categorias de receitas -->
<div class="page-header">
    <h1><strong>Receitas</strong> com sabor caseiro</h1>
    <div class="category-tags">
        @foreach (Categoria categoria in ViewBag.Categorias)
        {
            <span class="category-tag">
                <i class="@categoria.Icone"></i> @categoria.Nome
            </span>
        }
    </div>
</div>

<!-- Destaque sazonal (apenas apelo visual) -->
<div class="featured-recipe">
    <div class="featured-text">
        <h3><i class="fas fa-fire" style="color: var(--tomate);"></i> Receita em destaque - @ViewBag.Destaque.Nome</h3>
        <p>@ViewBag.Destaque.Descricao</p>
    </div>
    <a asp-action="Receita" asp-route-id="@ViewBag.Destaque.Id" class="featured-btn">Ver receita</a>
</div>

<!-- Grade de receitas 1 -->
<div class="section-title">
    <i class="fa-solid fa-utensils"></i>
    <span>Receitas populares</span>
</div>
<div class="recipe-grid">
    @foreach (Receita receita in Model)
    {
        <a asp-action="Receita" asp-route-id="@receita.Id" style="text-decoration: none;">
            <div class="recipe-card">
                <div class="card-img"
                    style="background-image: url('@receita.Foto');">
                    <span class="difficulty-badge">
                        <i class="far fa-clock"></i> @receita.TempoPreparo
                    </span>
                </div>
                <div class="card-content">
                    <h3 class="recipe-name">@receita.Nome</h3>
                    <div class="recipe-meta">
                        <span class="difficulty-indicator"><i class="fas fa-thermometer-half"></i> @receita.Dificuldade</span>
                        <span class="ingredients-count"><i class="fas fa-carrot"></i> @receita.Ingredientes.Count itens</span>
                    </div>
                    <div class="card-footer">
                        <span><i class="far fa-heart"></i>&nbsp;&nbsp;@receita.Favoritos.Count</span>
                        <span><i class="far fa-comment"></i>&nbsp;&nbsp;@receita.Comentarios.Count</span>
                    </div>
                </div>
            </div>
        </a>
    }
</div>