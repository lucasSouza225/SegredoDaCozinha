@{
    ViewData["Title"] = "Admin";
}

<div class="page-header">
    <h1>Painel <strong>Administrativo</strong></h1>
</div>

<div class="admin-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
    <a asp-action="Categorias" class="admin-card" style="background: #FFF8F0; padding: 2rem; border-radius: 20px; text-align: center; text-decoration: none;">
        <i class="fas fa-tags" style="font-size: 3rem; color: #F77F00;"></i>
        <h3>Categorias</h3>
        <p>Gerenciar categorias de receitas</p>
    </a>
    
    <a asp-action="Ingredientes" class="admin-card" style="background: #FFF8F0; padding: 2rem; border-radius: 20px; text-align: center; text-decoration: none;">
        <i class="fas fa-carrot" style="font-size: 3rem; color: #F77F00;"></i>
        <h3>Ingredientes</h3>
        <p>Gerenciar ingredientes</p>
    </a>
    
    <a asp-action="Receitas" class="admin-card" style="background: #FFF8F0; padding: 2rem; border-radius: 20px; text-align: center; text-decoration: none;">
        <i class="fas fa-book" style="font-size: 3rem; color: #F77F00;"></i>
        <h3>Receitas</h3>
        <p>Gerenciar receitas</p>
    </a>
</div>