@model Categoria
@{
    ViewData["Title"] = "Nova Categoria";
}

<h1>Nova Categoria</h1>

<form asp-action="CriarCategoria" method="post" style="background: #FFF8F0; padding: 2rem; border-radius: 20px;">
    <div class="form-group" style="margin-bottom: 1rem;">
        <label asp-for="Nome">Nome da Categoria</label>
        <input asp-for="Nome" class="form-control" style="width: 100%; padding: 0.8rem; border-radius: 10px; border: 1px solid #F4E1D2;">
    </div>
    
    <div class="form-group" style="margin-bottom: 1rem;">
        <label asp-for="Icone">Ícone (classe FontAwesome)</label>
        <input asp-for="Icone" class="form-control" style="width: 100%; padding: 0.8rem; border-radius: 10px; border: 1px solid #F4E1D2;">
        <small>Exemplo: fas fa-pizza-slice</small>
    </div>
    
    <button type="submit" class="featured-btn">Salvar</button>
    <a asp-action="Categorias" class="btn" style="margin-left: 1rem;">Cancelar</a>
</form>