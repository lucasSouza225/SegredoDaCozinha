@{
    ViewData["mainClass"] = ViewData["mainClass"] ?? "container";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SegredoDaCozinha | @ViewData["Title"]</title>
    <link rel="shortcut icon" href="~/img/logo.png" type="image/x-icon">
    <!-- Font Awesome para ícones (profile, config, etc) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/darkStyle.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- NAVBAR com usuário e dropdown -->
    <nav class="navbar">
        <a asp-action="Index" asp-controller="Home" class="logo-area">
            <div class="logo-icon">
                <img src="~/img/logo.png" alt="logo" width="50">
            </div>
            <div class="logo-text"> SegredoDaCozinha</div>
        </a>

        <partial name="_LoginPartial.cshtml" />
    </nav>

    <main class="@ViewData["mainClass"]">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

Altere o conteúdo do arquivo Index.cshtml da pasta Home:
@model List<Receita>
@{
    ViewData["Title"] = "Home";
}
<!-- Categorias de receitas -->
<div class="page-header">
    <h1><strong>Receitas</strong> com sabor caseiro</h1>
    <div class="category-tags">
        @foreach (Categoria categoria in ViewBag.Categorias)
        {
            <span class="category-tag">
                <i class="@categoria.Icone"></i> @categoria.Nome
            </span>
        }
    </div>
</div>

<!-- Destaque sazonal (apenas apelo visual) -->
<div class="featured-recipe">
    <div class="featured-text">
        <h3><i class="fas fa-fire" style="color: var(--tomate);"></i> Receita em destaque - @ViewBag.Destaque.Nome</h3>
        <p>@ViewBag.Destaque.Descricao</p>
    </div>
    <a asp-action="Receita" asp-route-id="@ViewBag.Destaque.Id" class="featured-btn">Ver receita</a>
</div>

<!-- Grade de receitas 1 -->
<div class="section-title">
    <i class="fa-solid fa-utensils"></i>
    <span>Receitas populares</span>
</div>
<div class="recipe-grid">
    @foreach (Receita receita in Model)
    {
        <a asp-action="Receita" asp-route-id="@receita.Id" style="text-decoration: none;">
            <div class="recipe-card">
                <div class="card-img"
                    style="background-image: url('@receita.Foto');">
                    <span class="difficulty-badge">
                        <i class="far fa-clock"></i> @receita.TempoPreparo
                    </span>
                </div>
                <div class="card-content">
                    <h3 class="recipe-name">@receita.Nome</h3>
                    <div class="recipe-meta">
                        <span class="difficulty-indicator"><i class="fas fa-thermometer-half"></i> @receita.Dificuldade</span>
                        <span class="ingredients-count"><i class="fas fa-carrot"></i> @receita.Ingredientes.Count itens</span>
                    </div>
                    <div class="card-footer">
                        <span><i class="far fa-heart"></i>&nbsp;&nbsp;@receita.Favoritos.Count</span>
                        <span><i class="far fa-comment"></i>&nbsp;&nbsp;@receita.Comentarios.Count</span>
                    </div>
                </div>
            </div>
        </a>
    }
</div>