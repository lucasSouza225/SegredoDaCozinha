@{
    ViewData["mainClass"] = ViewData["mainClass"] ?? "container";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Segredo da Cozinha | @ViewData["Title"]</title>
    <link rel="shortcut icon" href="~/img/logo.png" type="image/x-icon">
    <!-- Font Awesome para ícones -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/darkStyle.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- NAVBAR com usuário e dropdown -->
    <nav class="navbar">
        <a asp-action="Index" asp-controller="Home" class="logo-area">
            <div class="logo-icon">
                <img src="~/img/logo.png" alt="Segredo da Cozinha" width="40">
            </div>
            <div class="logo-text">Segredo da <span>Cozinha</span></div>
        </a>

        <partial name="_LoginPartial.cshtml" />
    </nav>

    <main class="@ViewData["mainClass"]">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; @DateTime.Now.Year - Segredo da Cozinha</p>
        <p style="font-size: 0.8rem; margin-top: 0.5rem;">
            <i class="fas fa-heart" style="color: var(--vermelho-segredo);"></i> 
            Compartilhe seus segredos culinários
        </p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>